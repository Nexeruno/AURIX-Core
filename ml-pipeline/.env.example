# Firebase Configuration
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# Firestore database location
FIRESTORE_PROJECT_ID=your-project-id
FIRESTORE_COLLECTION_PREFIX=users

# ML Pipeline Configuration
MIN_TRAINING_DATA_MONTHS=3
MIN_TRANSACTIONS_FOR_ML=30
TEST_TRAIN_SPLIT=0.2
RANDOM_FOREST_N_ESTIMATORS=100
RANDOM_FOREST_MAX_DEPTH=10

# Pipeline Mode
PIPELINE_MODE=shadow
# Options: shadow (Level 2 not active), production (Level 2 is active)

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Feature Engineering
INCLUDE_INCOME_DATA=false
# Whether to include income transactions in feature engineering
