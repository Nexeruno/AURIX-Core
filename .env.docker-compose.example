# Docker/Podman Compose example config.
# Copy this file to `.env.docker-compose` for local use.

COMPOSE_ENV=development

BACKEND_PORT=3000
BACKEND_SERVICE=node-backend
BACKEND_ENABLED=true
NODE_ENV=development
BACKEND_RESTART=unless-stopped

ML_RUNTIME_HOST=ml-runtime
ML_RUNTIME_PORT=5000
ML_RUNTIME_SERVICE=ml-runtime
ML_RUNTIME_EXPOSED_PORT=5000
ML_RUNTIME_ENABLED=true
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
ML_RUNTIME_RESTART=unless-stopped

COMPOSE_PROJECT_NAME=evidence-vydaju
DOCKER_NETWORK=ml-network
NETWORK_DRIVER=bridge

HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=5

LOG_DRIVER=json-file
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
LOG_LEVEL=info
DEBUG=false
