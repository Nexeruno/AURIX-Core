# ═══════════════════════════════════════════════════════════════════════════════
# FÁZA 6.2C: Local Development Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Usage:
#   cp .env.local.example .env.local
#   # Edit .env.local with your values
#   docker-compose up

# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════════

ENV=development

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND SERVICE (Node.js Express) — FÁZA 6.2A/6.2C
# ═══════════════════════════════════════════════════════════════════════════════

# Backend server port (exposed to host)
BACKEND_PORT=3000

# Backend service name (used internally by docker-compose)
BACKEND_SERVICE=node-backend

# Node environment
NODE_ENV=development

# Backend enable flag
BACKEND_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# ML RUNTIME SERVICE (Python Flask) — FÁZA 6.2A/6.2C
# ═══════════════════════════════════════════════════════════════════════════════

# ML Runtime host
# In docker-compose: ml-runtime (service name, NOT localhost!)
# Standalone Python: 127.0.0.1
ML_RUNTIME_HOST=ml-runtime

# ML Runtime port
ML_RUNTIME_PORT=5000

# ML Runtime service name (used internally by docker-compose)
ML_RUNTIME_SERVICE=ml-runtime

# ML Runtime exposed port (exposed to host)
ML_RUNTIME_EXPOSED_PORT=5000

# ML Runtime enable flag (FÁZA 6.1C)
ML_RUNTIME_ENABLED=true

# Python environment
PYTHONUNBUFFERED=1

# ═══════════════════════════════════════════════════════════════════════════════
# DOCKER COMPOSE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Docker compose project name
COMPOSE_PROJECT_NAME=evidence-vydaju

# Docker network name
DOCKER_NETWORK=ml-network

# ═══════════════════════════════════════════════════════════════════════════════
# LEGACY CONFIGURATION (Firebase, Brevo)
# ═══════════════════════════════════════════════════════════════════════════════

# Firebase config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin email (gets access to the admin panel)
VITE_ADMIN_EMAIL=admin@example.com

# Brevo config — for Cloud Functions (local development with emulator)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER=noreply@example.com

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING & DEBUG (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Debug mode
DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════
# HEALTH CHECKS & MONITORING (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Health check timeout (seconds)
HEALTH_CHECK_TIMEOUT=10

# Health check retries
HEALTH_CHECK_RETRIES=3

# ═══════════════════════════════════════════════════════════════════════════════
# SERVICE RESTART POLICIES (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# Backend restart policy (no, always, on-failure, unless-stopped)
BACKEND_RESTART=unless-stopped

# ML Runtime restart policy
RUNTIME_RESTART=unless-stopped
